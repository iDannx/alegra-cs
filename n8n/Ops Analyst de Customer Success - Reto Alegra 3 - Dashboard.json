        "jsCode": "const item = $input.first();\nlet text = item.json.output?.[0]?.content?.[0]?.text \n  || item.json.message?.content \n  || item.json.text \n  || JSON.stringify(item.json);\n\ntext = text.replace(/```json/g, '').replace(/```/g, '').trim();\n\nconst report = JSON.parse(text);\n\nreturn [{\n  json: {\n    title: report.title,\n    executive_summary: report.executive_summary,\n    key_metrics: JSON.stringify(report.key_metrics),\n    top_risk_clients: JSON.stringify(report.top_risk_clients),\n    action_items: report.action_items,\n    generated_by: 'ai_agent'\n  }\n}];"
